# :hover = para definir as ações que irão acontecer na animação

# transition: define a propriedade que vai ser animada e tempo de duração;

# tranform: scale(tamanhao); = usado para aumentar o container quando passa o mouse por cima

# tranforme: 
    translateX = movimenta na horizontal
    translateY = movmenta na vertical
    rotate(deg) = gira o elemento [deg = graus de rotação]

# @keyframes: divide a animação em frames para definir o comportamento da animação

# pulse: botão com efeito pulsante

# loader: efeito de carregamento

# slide: movimento de deslizar

# exemplo de animação:

/* 1. Definir os keyframes (quadros-chave) */
@keyframes moverDireita {
  from {
    transform: translateX(0);
    background-color: blue;
  }
  to {
    transform: translateX(300px);
    background-color: red;
  }
}

/* 2. Aplicar a animação ao elemento */
.caixa {
  width: 100px;
  height: 100px;
  animation-name: moverDireita;
  animation-duration: 2s;
  animation-iteration-count: infinite; /* Repete para sempre */
  animation-direction: alternate; /* Vai e volta */
}

# animation-name: Nome do @keyframes.

# animation-duration: Tempo de duração (ex: 2s, 500ms).

# animation-timing-function: Curva de velocidade (linear, ease-in-out).

# animation-iteration-count: Quantidade de vezes (infinite ou número).

# animation-fill-mode: Define o estado do elemento após a animação (ex: forwards para manter o estado final).

# exemplo para aumento de Escala (zoom) suave:

.botao {
  transition: transform 0.3s ease; /* Transição suave */
}
.botao:hover {
  transform: scale(1.1); /* Aumenta 10% */
}

# exemplo para mudança de cor e sombra:

.card {
  transition: all 0.4s ease-in-out;
}
.card:hover {
  background-color: #f0f0f0;
  box-shadow: 0 10px 20px rgba(0,0,0,0.2);
}

# exemplo para efeito de borda e fundo:

.btn {
  transition: 0.5s;
}
.btn:hover {
  background-color: purple;
  color: white;
  transform: translateY(-5px); /* Move para cima */
}




